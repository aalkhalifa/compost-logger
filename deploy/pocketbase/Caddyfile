# Caddy reverse proxy for PocketBase (Compost Logger backend).
# Replace pb.example.com with your real subdomain once the domain is purchased and its
# DNS A-record points at this box. Caddy then auto-issues a Let's Encrypt TLS cert.

pb.example.com {
	# PocketBase listens on localhost only (see pocketbase.service).
	reverse_proxy 127.0.0.1:8090

	# --- Optional: tighten CORS before public launch ---------------------------
	# PocketBase's default CORS is permissive (fine for beta). To restrict the API
	# to just the app origin, uncomment and let Caddy enforce it:
	#
	# @preflight method OPTIONS
	# handle @preflight {
	# 	header Access-Control-Allow-Origin "https://aalkhalifa.github.io"
	# 	header Access-Control-Allow-Methods "GET, POST, PATCH, DELETE, OPTIONS"
	# 	header Access-Control-Allow-Headers "Authorization, Content-Type"
	# 	respond 204
	# }
	# header Access-Control-Allow-Origin "https://aalkhalifa.github.io"
	# ---------------------------------------------------------------------------
}
