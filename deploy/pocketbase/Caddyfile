# Caddy reverse proxy for PocketBase (Compost Logger backend).
# Caddy auto-issues and renews a Let's Encrypt cert for this name.
#
# CORS is deliberately NOT handled here. PocketBase sets its own CORS headers, so adding
# them at this layer too would send two Access-Control-Allow-Origin headers, and browsers
# reject a response that carries more than one. The allowlist lives on PocketBase's
# --origins flag instead (see /etc/systemd/system/pocketbase.service).

api.compostlogger.com {
	# PocketBase listens on localhost only (see pocketbase.service).
	reverse_proxy 127.0.0.1:8090

	encode zstd gzip

	# Access logs go to journald (journalctl -u caddy). Deliberately not a file: the
	# packaged unit sandboxes filesystem writes, and journald already captures it.
}
