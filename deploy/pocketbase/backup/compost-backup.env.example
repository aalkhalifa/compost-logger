# Compost Logger backup secrets.
#
# Install to /etc/compost-backup.env, owned root:root, mode 0600.
#   install -o root -g root -m 0600 compost-backup.env.example /etc/compost-backup.env
#   # then fill in the real values
#
# THIS FILE IS THE ONLY PLACE ON THE BOX HOLDING BACKUP SECRETS.
# The repo (github.com/aalkhalifa/compost-logger) is PUBLIC - never commit the
# filled-in version. Only this .example, with placeholders, belongs in git.

# --- Cloudflare R2 ---------------------------------------------------------
# Account ID is the hex string in the R2 endpoint URL:
#   https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ACCOUNT_ID=REPLACE_WITH_CLOUDFLARE_ACCOUNT_ID

# R2 API token, scoped to "Object Read & Write" on the backup bucket ONLY.
# Do not use an account-wide token.
R2_ACCESS_KEY_ID=REPLACE_WITH_R2_ACCESS_KEY_ID
R2_SECRET_ACCESS_KEY=REPLACE_WITH_R2_SECRET_ACCESS_KEY

R2_BUCKET=compost-logger-backups

# --- healthchecks.io -------------------------------------------------------
# The ping UUID. Treat as a secret: anyone holding it can ping success and mask
# a real outage. Check should be period=1 day, grace=3h, alerting to
# aalkhalifa@gmail.com.
HC_UUID=REPLACE_WITH_HEALTHCHECKS_PING_UUID
